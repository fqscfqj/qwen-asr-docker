ASR_ENABLED_MODELS=0.6b,1.7b
ASR_DOWNLOAD_SOURCE=modelscope
ASR_ENABLE_ALIGNER=true
ASR_IDLE_UNLOAD_SECONDS=900
ASR_GPU_MEMORY_UTILIZATION=0.8
ASR_API_KEY=
ASR_MODELS_DIR=/models
ASR_PORT=8000
ASR_HOST=0.0.0.0
ASR_MAX_INFERENCE_BATCH_SIZE=32
ASR_MAX_NEW_TOKENS=4096
ASR_ALIGNER_DEVICE_MAP=cuda:0
ASR_ALIGNER_DTYPE=bfloat16
